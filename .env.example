# Database
DATABASE_URL="postgresql://user:password@localhost:5432/superkabe?schema=public"

# Redis (for BullMQ job processing)
REDIS_URL="redis://localhost:6379"

# Sending Platform API Keys
SMARTLEAD_API_KEY=""
INSTANTLY_API_KEY=""
EMAILBISON_API_KEY=""

# Email Validation (optional — enables API-level verification for Growth/Scale tiers)
MILLION_VERIFIER_API_KEY=""

# Slack Alerts (optional)
SLACK_WEBHOOK_URL=""

# System Configuration
METRICS_WORKER_INTERVAL_MS="60000"        # How often to check mailbox health (default: 60s)
MAILBOX_PAUSE_BOUNCES="5"                 # Bounce count threshold to auto-pause
SYSTEM_MODE="enforce"                     # observe | suggest | enforce
